# 저장소 루트에서 복사 후 사용: cp .env.example .env
# .env 는 Git에 올리지 마세요 (.gitignore 됨).

# --- Gemini (menu_allergy / food_image) ---
GEMINI_API_KEY=

# 선택: 기본 모델 덮어쓰기
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Spring Boot 급식 전송 (python -m crawler.push_menus) ---
# SPRING_MENUS_URL=http://localhost:8080/api/menus/ingest

# 선택: 서버가 Bearer 검증 시
# SPRING_API_TOKEN=

# 선택: 서버가 X-API-Key 검증 시
# SPRING_API_KEY=
