# 저장소 루트에서 복사 후 사용: cp .env.example .env
# .env 는 Git에 올리지 마세요 (.gitignore 됨).

# --- Gemini (menu_allergy / food_image) ---
GEMINI_API_KEY=

# 선택: 기본 모델 덮어쓰기
# GEMINI_MODEL=gemini-2.5-flash-lite

# --- Spring Boot 급식 전송 (python -m crawler.push_menus) ---
# SPRING_MENUS_URL=http://localhost:8080/api/menus/ingest

# 선택: 서버가 Bearer 검증 시
# SPRING_API_TOKEN=

# 선택: 서버가 X-API-Key 검증 시
# SPRING_API_KEY=

# --- Live service (python -m uvicorn user_features.live_service:app) ---
# 이미지 분석 결과 수신 API (예: http://localhost:8080/api/image-analysis/ingest)
# SPRING_IMAGE_ANALYSIS_URL=http://localhost:8080/api/image-analysis/ingest
# 이미지 식별(음식명만) 결과 수신 API
# SPRING_IMAGE_IDENTIFY_URL=http://localhost:8080/api/image-identify/ingest
# 텍스트 음식 분석 결과 수신 API
# SPRING_TEXT_ANALYSIS_URL=http://localhost:8080/api/food-analysis/ingest
# 주간 크롤링 스케줄 (기본: 월요일 06:00, Asia/Seoul)
# WEEKLY_CRAWL_DAY=mon
# WEEKLY_CRAWL_HOUR=6
# WEEKLY_CRAWL_MINUTE=0
# SERVICE_TIMEZONE=Asia/Seoul
# WEEKLY_MENU_MODEL=gemini-2.5-flash-lite
# WEEKLY_MENU_BATCH_SIZE=4
# WEEKLY_MENU_SLEEP_SECONDS=21.0
# I18N_LOCALE=en
# 직접 이미지 상세분석 엔드포인트(/analyze-image-and-forward) 활성화 여부 (기본 비활성화)
# ENABLE_DIRECT_IMAGE_ANALYSIS=false
