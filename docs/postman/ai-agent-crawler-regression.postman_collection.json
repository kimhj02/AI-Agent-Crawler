    "name": "AI-Agent-Crawler Spring Compat Regression",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Spring Swagger 호환 엔드포인트 회귀 테스트용 컬렉션"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"idToken\":\"dummy-id-token\",\"deviceId\":\"device-1\"}"
        },
        "url": "{{baseUrl}}/auth/login"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const jsonData = pm.response.json();",
              "pm.test('has access token', function () {",
              "  pm.expect(jsonData.success).to.eql(true);",
              "  pm.expect(jsonData.data.accessToken).to.be.a('string');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Settings - Get Language (Auth)",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/v1/settings/language"
      }
    },
    {
      "name": "Settings - Patch Language",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\"languageCode\":\"en\"}"
        },
        "url": "{{baseUrl}}/api/v1/settings/language"
      }
    },
    {
