            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/mealcrawl/weekly-meals?cafeteriaId=1&weekStartDate=2026-04-27",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "mealcrawl",
            "weekly-meals"
          ],
          "query": [
